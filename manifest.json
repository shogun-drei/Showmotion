{
  "manifest_version": 3,
  "name": "Showmotion",
  "version": "0.1.0",
  "description": "Showmotion: Animations for Pokemon Showdown.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab"],
  "browser_specific_settings": {
    "gecko": {
      "id": "showmotion@eigong.com",
      "strict_min_version": "128.0"
    }
  },
  "action": {
    "default_title": "Showmotion",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://play.pokemonshowdown.com/*"],
      "js": ["boot.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["*"],
      "matches": ["*://play.pokemonshowdown.com/*"]
    }
  ]
}
